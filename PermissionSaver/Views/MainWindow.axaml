<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PermissionSaver.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="750"
        x:Class="PermissionSaver.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Permission Saver - Сохранение прав доступа"
        Width="900" Height="750">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<ScrollViewer>
		<StackPanel Margin="20" Spacing="15">

			<TextBlock Text="🔐 Permission Saver" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
			<TextBlock Text="Сохранение и восстановление прав доступа к файлам и папкам"
                      FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>

			<Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="15" CornerRadius="8"
                    Background="#F9F9F9">
				<StackPanel Spacing="10">
					<TextBlock Text="📦 Сериализация (Сохранение)" FontSize="18" FontWeight="Bold"
                              Foreground="#0066CC"/>

					<Grid ColumnDefinitions="*,Auto" Margin="0,10,0,5">
						<StackPanel Grid.Column="0" Spacing="5">
							<TextBlock Text="Источник (файл или папка):" FontWeight="SemiBold"/>
							<TextBox Name="SerializeSourceTextBox" Text="{Binding SerializeSourcePath}"
                                    Watermark="Путь к файлу или папке"/>
						</StackPanel>
						<Button Grid.Column="1" Content="📁 Обзор" Margin="5,0,0,0"
                               Click="SerializeSourceBrowse_Click"
                               VerticalAlignment="Bottom" Padding="10,5"/>
					</Grid>

					<Grid ColumnDefinitions="*,Auto" Margin="0,5,0,5">
						<StackPanel Grid.Column="0" Spacing="5">
							<TextBlock Text="JSON файл (куда сохранить):" FontWeight="SemiBold"/>
							<TextBox Name="SerializeDestTextBox" Text="{Binding SerializeDestPath}"
                                    Watermark="Путь для сохранения .json файла"/>
						</StackPanel>
						<Button Grid.Column="1" Content="💾 Сохранить как..." Margin="5,0,0,0"
                               Click="SerializeDestBrowse_Click"
                               VerticalAlignment="Bottom" Padding="10,5"/>
					</Grid>

					<Button Content="💾 Сохранить файл и права" Command="{Binding SerializeCommand}"
                           IsEnabled="{Binding !IsBusy}" HorizontalAlignment="Left"
                           Padding="15,8" Background="#0066CC" Foreground="White" Margin="0,10,0,0"/>
				</StackPanel>
			</Border>

			<Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="15" CornerRadius="8"
                    Background="#F9F9F9">
				<StackPanel Spacing="10">
					<TextBlock Text="📥 Десериализация (Восстановление)" FontSize="18" FontWeight="Bold"
                              Foreground="#009900"/>

					<Grid ColumnDefinitions="*,Auto" Margin="0,10,0,5">
						<StackPanel Grid.Column="0" Spacing="5">
							<TextBlock Text="JSON файл:" FontWeight="SemiBold"/>
							<TextBox Name="DeserializeSourceTextBox" Text="{Binding DeserializeSourcePath}"
                                    Watermark="Путь к .json файлу"/>
						</StackPanel>
						<Button Grid.Column="1" Content="📁 Открыть файл" Margin="5,0,0,0"
                               Click="DeserializeSourceBrowse_Click"
                               VerticalAlignment="Bottom" Padding="10,5"/>
					</Grid>

					<Grid ColumnDefinitions="*,Auto" Margin="0,5,0,5">
						<StackPanel Grid.Column="0" Spacing="5">
							<TextBlock Text="Папка назначения:" FontWeight="SemiBold"/>
							<TextBox Name="DeserializeDestTextBox" Text="{Binding DeserializeDestPath}"
                                    Watermark="Папка для восстановления файлов"/>
						</StackPanel>
						<Button Grid.Column="1" Content="📂 Выбрать папку" Margin="5,0,0,0"
                               Click="DeserializeDestBrowse_Click"
                               VerticalAlignment="Bottom" Padding="10,5"/>
					</Grid>

					<Button Content="📂 Восстановить файл и права" Command="{Binding DeserializeCommand}"
                           IsEnabled="{Binding !IsBusy}" HorizontalAlignment="Left"
                           Padding="15,8" Background="#009900" Foreground="White" Margin="0,10,0,0"/>
				</StackPanel>
			</Border>

			<Border Background="#2D2D2D" Padding="10" CornerRadius="5">
				<StackPanel>
					<TextBlock Text="📋 Лог операций:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
					<TextBox Text="{Binding LogText}" IsReadOnly="True" AcceptsReturn="True"
                            TextWrapping="Wrap" Height="200" FontFamily="Consolas,Monaco"
                            Foreground="#00FF00" Background="#1E1E1E" BorderThickness="0"/>
				</StackPanel>
			</Border>

			<TextBlock Text="Поддерживаемые ОС: Windows, Linux, macOS"
                      HorizontalAlignment="Center" Foreground="Gray" FontSize="12"/>
		</StackPanel>
	</ScrollViewer>
</Window>